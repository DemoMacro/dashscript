// feature-tour — a tour of the DashScript subset that transpiles to idiomatic Rust.

interface Vector {
  x: number;
  y: number;
}

interface Item {
  name: string;
  tag?: string;
}

type Kind = "linear" | "rotational";

function magnitude(v: Vector): number {
  return Math.sqrt(v.x ** 2 + v.y ** 2);
}

function makeVector(x: number, y: number): Vector {
  return { x: x, y: y };
}

function sum(v: Vector): number {
  return v.x + v.y;
}

function label(kind: Kind): string {
  switch (kind) {
    case "linear": return "linear";
    case "rotational": return "rotational";
  }
}

function describe(v: Vector): string {
  const mag = magnitude(v);
  return "magnitude " + mag + " => " + (mag > 5 ? "large" : "small");
}

type Shape = { kind: "circle"; radius: number } | { kind: "square"; side: number };

function area(s: Shape): number {
  switch (s.kind) {
    case "circle": return s.radius * s.radius;
    case "square": return s.side * s.side;
  }
}

function identity<T>(x: T): T {
  return x;
}

function greet(name: string, greeting: string = "hello"): string {
  return greeting + ", " + name;
}

function main(): void {
  const v: Vector = { x: 3, y: 4 };
  console.log("magnitude:", magnitude(v));

  const mv = makeVector(5, 6);
  console.log("makeVector:", mv.x, mv.y);

  // object destructuring (struct pattern)
  const dv: Vector = makeVector(7, 8);
  const { x, y } = dv;
  console.log("destructured:", x, y);

  // object literal as an argument (borrows its name from the param type)
  console.log("sum:", sum({ x: 3, y: 4 }));

  // Record (a map type) → HashMap
  const scores: Record<string, number> = { alice: 90, bob: 85 };
  console.log("record size:", scores.length);
  console.log("alice:", scores["alice"]);
  // Object.keys/values on a Record (HashMap) → its keys/values as Vecs
  console.log("keys:", Object.keys(scores).length);
  console.log("values:", Object.values(scores).length);
  // `key in record` → HashMap::contains_key
  console.log("has alice:", "alice" in scores);
  // computed key: `{ [k]: v }` → a dynamic HashMap entry
  const dynName = "dynamic";
  const byKey: Record<string, number> = { [dynName]: 42 };
  console.log("computed key:", byKey["dynamic"]);

  // mutable map: `m["k"] = v` → `m.insert("k".to_string(), v)`
  let prices: Record<string, number> = { apple: 3 };
  prices["banana"] = 2;
  console.log("prices size:", prices.length);
  console.log("2^10:", 2 ** 10);
  console.log("trig:", Math.sin(0), Math.cos(0));
  console.log("log:", Math.log(Math.E));
  // Math.hypot(a,b) → (a² + b²).sqrt(); std has no f64::hypot
  console.log("hypot:", Math.hypot(3, 4));
  // int helpers: clz32 → leading_zeros of x as u32 (1 → 31)
  console.log("clz32:", Math.clz32(1));
  console.log("bitwise:", 6 & 3);
  console.log("shift:", 1 << 3);
  console.log("bitnot:", ~0);

  const lin: Kind = "linear";
  const rot: Kind = "rotational";
  console.log("kinds:", label(lin), label(rot));

  const u: Vector = { x: 1, y: 2 };
  console.log(describe(u));

  // object spread: `{ ...base, field: val }` → `Struct { field: val, ..base }`
  const base: Vector = makeVector(2, 5);
  const updated: Vector = { ...base, x: 99 };
  console.log("updated:", updated.x, updated.y);

  // discriminated union: construct a variant, then destructure it in a switch
  const c: Shape = { kind: "circle", radius: 3 };
  console.log("circle area:", area(c));
  const sq: Shape = { kind: "square", side: 4 };
  console.log("square area:", area(sq));

  // optional fields: `?:` → Option<T>; omitting one fills `None`
  const widget: Item = { name: "widget" };
  console.log("item name:", widget.name);
  const tagged: Item = { name: "gadget", tag: "new" };
  console.log("item tag:", tagged.tag!);
  // destructure default: `{ tag = "none" }` → unwrap_or on the Option field
  const { tag = "none" } = widget;
  console.log("default tag:", tag);

  // generic function: `<T>` passes through; Rust monomorphizes each call
  console.log("identity:", identity(42));

  // default parameter: omitted value passes None; a supplied one wraps Some
  console.log("default:", greet("world"));
  console.log("override:", greet("world", "hi"));

  // optional chaining: `v?.x` → as_ref().map; `?? default` → unwrap_or
  const none: Vector | null = null;
  console.log("chain none:", none?.x ?? -1);

  // string methods + concatenation
  const greeting = "Hello, World";
  console.log(greeting.toLowerCase());
  console.log(greeting.includes("World"));
  console.log("ab".repeat(3));
  console.log("replaceAll:", "a-a-a".replaceAll("a", "b"));

  // string → string[]: split maps to split().map(to_string).collect()
  const parts = "a,b,c".split(",");
  console.log("split:", parts.length);
  console.log("str indexOf:", "hello".indexOf("ll"));

  // global conversion: `String(x)` → `format!`; `parseInt(s)` → `s.parse()`
  console.log("as string:", String(42));
  console.log("number:", Number("3.14"));
  console.log("parsed:", parseInt("100"));
  // boolean coercion: `Boolean(x)` → truthiness (empty string / zero → false)
  console.log("bool:", Boolean("hi"), Boolean(""));
  console.log("sliced str:", "hello".slice(1, 4));
  console.log("trimmed:", "  ab".trimStart());
  console.log("charAt:", "hello".charAt(1));
  console.log("charCode:", "A".charCodeAt(0));
  console.log("fromCharCode:", String.fromCharCode(66));
  // string padding: `.padStart(n)`/`.padEnd(n)` → format! alignment (spaces)
  console.log("pad:", "[" + "5".padStart(3) + "]", "[" + "5".padEnd(3) + "]");
  // pad with a fill string: "5".padStart(3,"0") → "005"; multi-char pads cycle
  console.log("pad ch:", "5".padStart(3, "0"), "5".padEnd(4, "ab"));

  // number formatting: `x.toFixed(n)` → format! with n decimal places
  const pi = 3.14159;
  console.log("fixed:", pi.toFixed(2));

  // number → radix string: `(255).toString(16)` → format!("{:x}", … as u32)
  console.log("hex:", (255).toString(16));

  // arrow function as a value
  const square = (n: number) => n * n;
  console.log("square:", square(9));

  // array callbacks: `.map` (callback owns via .copied) and `.filter`
  // (callback borrows, so its param destructures as `|&n|`).
  const xs: number[] = [1, 2, 3];
  const doubled = xs.map((n) => n * 2);
  console.log("doubled:", doubled[0], doubled[1], doubled[2]);
  const evens = xs.filter((n) => n > 1);
  console.log("evens:", evens.length);
  const sliced = xs.slice(1, 3);
  console.log("slice:", sliced[0], sliced[1]);
  // array `.at(i)` → signed index (negatives count from the end)
  console.log("at:", xs.at(2), xs.at(-1));
  console.log("indexOf:", xs.indexOf(2));
  console.log("lastIndexOf:", xs.lastIndexOf(2));
  // reverse search: findLastIndex → rposition; reduceRight → rev().fold
  console.log("findLastIndex >1:", xs.findLastIndex((n) => n > 1));
  console.log("reduceRight:", xs.reduceRight((a, b) => a - b, 0));
  console.log("findIndex >1:", xs.findIndex((n) => n > 1));
  console.log("includes 2:", xs.includes(2));
  console.log("find 2:", xs.find((n) => n === 2)!);
  console.log("some >2:", xs.some((n) => n > 2));
  console.log("every >0:", xs.every((n) => n > 0));
  console.log("join:", xs.join("-"));
  console.log("reduce:", xs.reduce((a, b) => a + b, 0));
  // flatMap: map each element to an array, then flatten into one
  const pairs = xs.flatMap((n) => [n, n * 2]);
  console.log("flatMap:", pairs.length);
  // nested array + `.flat()` (one level) → Vec::concat
  const nested: number[][] = [[1, 2], [3]];
  console.log("flat:", nested.flat().length);

  // array iteration with side effects: `.forEach(cb)` → for_each
  xs.forEach((n) => console.log("each:", n));

  // array spread: `[...xs, v]` → `[xs.as_slice(), &[v][..]].concat()`
  const tail: number[] = [...xs, 4];
  console.log("tail:", tail.length);

  // array destructuring: `const [a, b] = xs` → positional indexed lets
  const pair: number[] = [10, 20];
  const [first, second] = pair;
  console.log("array destructure:", first, second);
  // array destructuring with rest: `...rest` → the remaining slice as a Vec
  const [head, ...tail] = xs;
  console.log("rest destructure:", head, tail.length);

  // in-place array mutations: `.sort()` (numeric ascending) and `.reverse()`
  // need a `let` (mutable) array; `.concat(ys)` returns a new array.
  let nums: number[] = [3, 1, 2];
  nums.sort();
  console.log("sorted:", nums[0], nums[1], nums[2]);
  nums.reverse();
  console.log("reversed:", nums[0], nums[1], nums[2]);
  nums.fill(7);
  console.log("filled:", nums[0], nums[1], nums[2]);
  const more: number[] = [4, 5];
  const combined = nums.concat(more);
  console.log("concat size:", combined.length);

  // mutate an element: `ys[i] = v` → `ys[i as usize] = v`
  let ys: number[] = [1, 2, 3];
  ys[0] = 9;
  console.log("ys[0]:", ys[0]);

  // mutate a field: `v.x = v` → `v.x = v`
  let wv: Vector = makeVector(1, 2);
  wv.x = 10;
  console.log("wv.x:", wv.x);

  // loops: a C-style for, a for-of, break and continue
  let sum = 0;
  for (let i = 1; i <= 5; i++) {
    sum += i;
  }
  console.log("sum 1..5:", sum);

  let counted = 0;
  for (const n of [2, 4, 6, 8]) {
    if (n == 4) {
      continue;
    }
    if (n == 8) {
      break;
    }
    counted += n;
  }
  console.log("counted:", counted);

  // truthiness on a Vec and on an Option
  const items: number[] = [];
  if (items) {
    console.log("nonempty");
  } else {
    console.log("empty");
  }
  const maybe: number | null = 42;
  if (maybe) {
    console.log("set:", maybe!);
  }

  // a `.ds` name that is a Rust keyword (`type`) → a raw identifier `r#type`
  const type = 99;
  console.log("keyword:", type);
}
